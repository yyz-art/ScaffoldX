<UserControl x:Class="ScaffoldX.Plugin.Scaffold.Views.ScaffoldWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stepper -->
        <Border Grid.Row="0" Margin="16,16,16,8" Background="{DynamicResource MaterialDesignPaper}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="24" Height="24" Fill="{Binding Step1Brush}" Margin="0,0,8,0"/>
                    <TextBlock Text="基础信息" VerticalAlignment="Center" FontWeight="{Binding Step1FontWeight}"/>
                </StackPanel>

                <Separator Grid.Column="1" Width="40" VerticalAlignment="Center" Margin="8,0"/>

                <!-- Step 2 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="24" Height="24" Fill="{Binding Step2Brush}" Margin="0,0,8,0"/>
                    <TextBlock Text="设备配置" VerticalAlignment="Center" FontWeight="{Binding Step2FontWeight}"/>
                </StackPanel>

                <Separator Grid.Column="3" Width="40" VerticalAlignment="Center" Margin="8,0"/>

                <!-- Step 3 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="24" Height="24" Fill="{Binding Step3Brush}" Margin="0,0,8,0"/>
                    <TextBlock Text="功能配置" VerticalAlignment="Center" FontWeight="{Binding Step3FontWeight}"/>
                </StackPanel>

                <Separator Grid.Column="5" Width="40" VerticalAlignment="Center" Margin="8,0"/>

                <!-- Step 4 -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="24" Height="24" Fill="{Binding Step4Brush}" Margin="0,0,8,0"/>
                    <TextBlock Text="系统配置" VerticalAlignment="Center" FontWeight="{Binding Step4FontWeight}"/>
                </StackPanel>

                <Separator Grid.Column="7" Width="40" VerticalAlignment="Center" Margin="8,0"/>

                <!-- Step 5 -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="24" Height="24" Fill="{Binding Step5Brush}" Margin="0,0,8,0"/>
                    <TextBlock Text="确认生成" VerticalAlignment="Center" FontWeight="{Binding Step5FontWeight}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Row="1" Margin="16,8,16,8" Background="{DynamicResource MaterialDesignPaper}">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>

        <!-- Navigation Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,8,16,16">
            <Button Content="上一步"
                    Command="{Binding PreviousCommand}"
                    IsEnabled="{Binding CanGoPrevious}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0"
                    Padding="16,8"/>
            <Button Content="{Binding NextButtonText}"
                    Command="{Binding NextCommand}"
                    IsEnabled="{Binding CanGoNext}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Padding="16,8"/>
        </StackPanel>
    </Grid>
</UserControl>
