<UserControl x:Class="ScaffoldX.App.Views.AnnotationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:ScaffoldX.App.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- 边界框颜色转换器 -->
        <SolidColorBrush x:Key="BoxStrokeBrush" Color="#FF0000"/>

        <!-- 弧度转角度转换器 -->
        <converters:RadiansToDegreesConverter x:Key="RadiansToDegreesConverter"/>

        <!-- 边界框标注模板 -->
        <DataTemplate x:Key="BoundingBoxTemplate">
            <StackPanel>
                <TextBlock FontWeight="SemiBold">
                    <Run Text="类别: "/>
                    <Run Text="{Binding ClassName, Mode=OneWay}"/>
                    <Run Text=" | 中心: ("/>
                    <Run Text="{Binding CenterX, StringFormat='{}{0:F3}', Mode=OneWay}"/>
                    <Run Text=", "/>
                    <Run Text="{Binding CenterY, StringFormat='{}{0:F3}', Mode=OneWay}"/>
                    <Run Text=")"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="尺寸: "/>
                    <Run Text="{Binding Width, StringFormat='{}{0:F3}', Mode=OneWay}"/>
                    <Run Text=" x "/>
                    <Run Text="{Binding Height, StringFormat='{}{0:F3}', Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- 多边形标注模板 -->
        <DataTemplate x:Key="PolygonTemplate">
            <StackPanel>
                <TextBlock FontWeight="SemiBold">
                    <Run Text="类别: "/>
                    <Run Text="{Binding ClassName, Mode=OneWay}"/>
                    <Run Text=" | 多边形: "/>
                    <Run Text="{Binding Points.Count, Mode=OneWay}"/>
                    <Run Text=" 个点"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- OBB 标注模板 -->
        <DataTemplate x:Key="OrientedBoundingBoxTemplate">
            <StackPanel>
                <TextBlock FontWeight="SemiBold">
                    <Run Text="类别: "/>
                    <Run Text="{Binding ClassName, Mode=OneWay}"/>
                    <Run Text=" | OBB: "/>
                    <Run Text="{Binding Width, StringFormat='{}{0:F3}', Mode=OneWay}"/>
                    <Run Text=" x "/>
                    <Run Text="{Binding Height, StringFormat='{}{0:F3}', Mode=OneWay}"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="角度: "/>
                    <Run Text="{Binding Angle, Converter={StaticResource RadiansToDegreesConverter}, Mode=OneWay}"/>
                    <Run Text="°"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- 分割标注模板 -->
        <DataTemplate x:Key="SegmentationTemplate">
            <StackPanel>
                <TextBlock FontWeight="SemiBold">
                    <Run Text="分割: "/>
                    <Run Text="{Binding ClassName, Mode=OneWay}"/>
                    <Run Text=" | 置信度: "/>
                    <Run Text="{Binding Confidence, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="多边形: "/>
                    <Run Text="{Binding Polygon.Count, Mode=OneWay}"/>
                    <Run Text=" 个点"/>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- 标注模板选择器 -->
        <converters:AnnotationTemplateSelector x:Key="AnnotationTemplateSelector"
            BoundingBoxTemplate="{StaticResource BoundingBoxTemplate}"
            PolygonTemplate="{StaticResource PolygonTemplate}"
            OrientedBoundingBoxTemplate="{StaticResource OrientedBoundingBoxTemplate}"
            SegmentationTemplate="{StaticResource SegmentationTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧面板：项目信息和类别管理 -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,4,0">
            <StackPanel Margin="16">
                <!-- 项目操作 -->
                <TextBlock Text="项目操作" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="新建项目" Command="{Binding NewProjectCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button Content="打开项目" Command="{Binding OpenProjectCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>
                <Button Content="保存项目" Command="{Binding SaveProjectCommand}" Margin="0,0,0,16"
                        Style="{StaticResource MaterialDesignFlatButton}"/>

                <!-- 统计信息 -->
                <TextBlock Text="统计信息" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding ProjectName, StringFormat='项目: {0}'}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding AnnotationProgressText}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ImageNavigationText, StringFormat='图像: {0}'}" Margin="0,0,0,16"/>

                <!-- 类别管理 -->
                <TextBlock Text="类别管理" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                <ListBox ItemsSource="{Binding Classes}" SelectedIndex="{Binding SelectedClassIndex}"
                         Height="200" Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="16" Height="16" Margin="0,0,8,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding Color}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal">
                    <Button Content="添加类别" Command="{Binding AddClassCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button Content="删除类别" Command="{Binding RemoveClassCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>

                <!-- 操作按钮 -->
                <TextBlock Text="操作" FontWeight="Bold" FontSize="16" Margin="0,16,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="添加图像" Command="{Binding AddImagesCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                    <Button Content="添加文件夹" Command="{Binding AddFolderCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>

                <!-- 撤销/重做 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="撤销" Command="{Binding UndoCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button Content="重做" Command="{Binding RedoCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>

                <!-- 绘制模式 -->
                <TextBlock Text="绘制模式" FontWeight="Bold" FontSize="14" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{Binding PolygonModeButtonText}"
                            Command="{Binding TogglePolygonModeCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4CAF50"/>
                    <Button Content="完成多边形" Command="{Binding FinishPolygonCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            IsEnabled="{Binding IsPolygonMode}"/>
                    <Button Content="取消" Command="{Binding CancelPolygonCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            IsEnabled="{Binding IsPolygonMode}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{Binding ObbModeButtonText}"
                            Command="{Binding ToggleObbModeCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#FF9800"/>
                    <Button Content="完成 OBB" Command="{Binding FinishObbCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            IsEnabled="{Binding IsRotatingObb}"/>
                    <Button Content="取消" Command="{Binding CancelObbCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            IsEnabled="{Binding IsDrawingObb}"/>
                </StackPanel>

                <!-- 导入标注 -->
                <Button Content="导入 YOLO 标注" Command="{Binding ImportAnnotationsCommand}" Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignFlatButton}"/>

                <!-- 导出 -->
                <TextBlock Text="导出格式" FontWeight="Bold" FontSize="14" Margin="0,8,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="YOLO" Command="{Binding ExportYoloCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}" Background="#4CAF50"/>
                    <Button Content="COCO" Command="{Binding ExportCocoCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}" Background="#2196F3"/>
                    <Button Content="VOC" Command="{Binding ExportVocCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}" Background="#FF9800"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="DOTA" Command="{Binding ExportDotCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignRaisedButton}" Background="#E91E63"/>
                    <Button Content="MOT" Command="{Binding ExportMotCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}" Background="#9C27B0"/>
                </StackPanel>

                <!-- 自动标注 -->
                <TextBlock Text="自动标注" FontWeight="Bold" FontSize="16" Margin="0,16,0,12"/>
                <TextBlock Text="{Binding LoadedModelName}" Foreground="#757575" FontSize="12" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="加载模型" Command="{Binding LoadModelCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button Content="卸载" Command="{Binding UnloadModelCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            IsEnabled="{Binding IsModelLoaded}"/>
                </StackPanel>
                <TextBlock Text="置信度阈值" FontSize="12" Margin="0,0,0,4"/>
                <Slider Minimum="0.1" Maximum="0.95" Value="{Binding ConfidenceThreshold}"
                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                        Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ConfidenceThreshold, StringFormat='{}{0:F2}'}"
                           FontSize="11" Foreground="#757575" Margin="0,0,0,8"/>
                <Button Content="自动标注当前图像" Command="{Binding AutoDetectCurrentCommand}" Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignRaisedButton}" Background="#9C27B0"
                        IsEnabled="{Binding IsModelLoaded}"/>
                <Button Content="批量自动标注" Command="{Binding AutoDetectAllCommand}" Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignRaisedButton}" Background="#673AB7"
                        IsEnabled="{Binding IsModelLoaded}"/>
                <!-- 自动标注进度 -->
                <ProgressBar Minimum="0" Maximum="{Binding AutoDetectTotal}"
                             Value="{Binding AutoDetectProgress, Mode=OneWay}"
                             Visibility="{Binding IsAutoDetecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Height="8" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding AutoDetectProgressText}" FontSize="11"
                           Foreground="#757575"
                           Visibility="{Binding IsAutoDetecting, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- ── SAM 3 智能分割 ──────────────────────────────── -->
                <Expander Header="SAM 3 智能分割" Margin="0,16,0,0" IsExpanded="True">
                    <StackPanel>
                        <!-- 加载 SAM 3 模型 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="加载 SAM 3 模型" Command="{Binding LoadSam3ModelCommand}" Margin="0,0,8,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#E91E63"/>
                            <Button Content="卸载" Command="{Binding UnloadModelCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    IsEnabled="{Binding IsSam3ModelLoaded}"/>
                        </StackPanel>
                        <TextBlock FontSize="11" Foreground="#757575" Margin="0,0,0,8" TextWrapping="Wrap">
                            <Run Text="目录需含: encoder.pt + text_encoder.pt + decoder.pt"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="#757575" Margin="0,0,0,8">
                            <Run Text="模型状态: "/>
                            <Run Text="{Binding IsSam3ModelLoaded, Mode=OneWay}"/>
                        </TextBlock>

                        <!-- 文本提示模式 -->
                        <TextBlock Text="文本提示分割" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding Sam3TextPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="输入类别名（逗号分隔，如: 螺丝,垫片）"
                                 Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="文本分割当前图" Command="{Binding Sam3SegmentByTextCommand}" Margin="0,0,8,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#00BCD4"
                                    IsEnabled="{Binding IsSam3ModelLoaded}"/>
                            <Button Content="批量分割" Command="{Binding Sam3SegmentAllByTextCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#009688"
                                    IsEnabled="{Binding IsSam3ModelLoaded}"/>
                        </StackPanel>

                        <Separator Margin="0,4,0,8"/>

                        <!-- 点提示模式 -->
                        <TextBlock Text="点击提示分割" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <TextBlock Text="左键=正点(绿)  右键=负点(红)" FontSize="11" Foreground="#757575" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="进入点模式" Command="{Binding Sam3EnterPointModeCommand}" Margin="0,0,8,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#FF5722"
                                    IsEnabled="{Binding IsSam3ModelLoaded}"/>
                            <Button Content="接受掩码" Command="{Binding Sam3AcceptMaskCommand}" Margin="0,0,8,0"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#4CAF50"
                                    IsEnabled="{Binding HasSam3MaskPreview}"/>
                            <Button Content="清除" Command="{Binding Sam3ClearPointsCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                        </StackPanel>

                        <Separator Margin="0,4,0,8"/>

                        <!-- 参考图模式 -->
                        <TextBlock Text="参考图分割" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="选择参考图" Command="{Binding Sam3SelectReferenceCommand}" Margin="0,0,8,0"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                            <Button Content="查找相似" Command="{Binding Sam3SegmentByReferenceCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#673AB7"
                                    IsEnabled="{Binding IsSam3ModelLoaded}"/>
                        </StackPanel>

                        <!-- 处理进度 -->
                        <ProgressBar IsIndeterminate="{Binding IsSam3Processing}"
                                     Visibility="{Binding IsSam3Processing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     Height="4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 中间面板：图像标注区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 图像导航 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,8">
                <Button Content="上一张" Command="{Binding PreviousImageCommand}" Margin="0,0,8,0"
                        Style="{StaticResource MaterialDesignFlatButton}"/>
                <Button Content="下一张" Command="{Binding NextImageCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"/>
                <TextBlock Text="{Binding ImageNavigationText}" VerticalAlignment="Center" Margin="16,0"/>
            </StackPanel>

            <!-- 图像显示区域 -->
            <Border Grid.Row="1" Background="#212121" Margin="8">
                <Grid>
                    <!-- 图像（Grid 布局，自动填充可用空间） -->
                    <Image Source="{Binding CurrentImage}" Stretch="Uniform"
                           x:Name="AnnotationImage"/>

                    <!-- 绘制层 Canvas（覆盖在图像上方，不遮挡图像布局） -->
                    <Canvas x:Name="AnnotationCanvas" ClipToBounds="True"
                            Background="Transparent"
                            MouseDown="AnnotationCanvas_MouseDown"
                            MouseMove="AnnotationCanvas_MouseMove"
                        MouseUp="AnnotationCanvas_MouseUp">

                        <!-- 边界框绘制层 -->
                        <Canvas x:Name="BoxesCanvas"/>

                        <!-- 当前绘制的边界框 -->
                        <Rectangle x:Name="DrawingRect" Stroke="#FF0000" StrokeThickness="2"
                                   StrokeDashArray="4 2" Visibility="Collapsed"/>

                        <!-- 当前绘制的多边形 -->
                        <Polyline x:Name="DrawingPolygon" Stroke="#00FF00" StrokeThickness="2"
                                  StrokeDashArray="4 2" Fill="#2200FF00"
                                  Visibility="Collapsed"/>

                        <!-- 当前绘制的 OBB（旋转边界框） -->
                        <Rectangle x:Name="DrawingObbRect" Stroke="#FF9800" StrokeThickness="2"
                                   StrokeDashArray="4 2" Fill="#22FF9800"
                                   Visibility="Collapsed"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- 状态栏 -->
            <Grid Grid.Row="2" Margin="16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="#757575" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding ZoomLevelText}"
                           Foreground="#757575" VerticalAlignment="Center"
                           Margin="16,0,8,0" FontSize="12" FontWeight="SemiBold"/>
                <Button Grid.Column="2" Content="重置缩放"
                        Command="{Binding ResetZoomCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        FontSize="11" Padding="4,2"/>
            </Grid>
        </Grid>

        <!-- 右侧面板：标注列表和统计 -->
        <Border Grid.Column="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
            <StackPanel Margin="16">
                <TextBlock Text="标注列表" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                <TextBlock Text="{Binding TotalAnnotationCount, StringFormat='数量: {0}'}" Margin="0,0,0,8"/>

                <ListBox ItemsSource="{Binding AllAnnotations}" SelectedItem="{Binding SelectedBox}"
                         ItemTemplateSelector="{StaticResource AnnotationTemplateSelector}"
                         Height="320" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="删除选中" Command="{Binding DeleteSelectedBoxCommand}" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button Content="清空全部" Command="{Binding ClearAllBoxesCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>

                <!-- 标注统计 -->
                <TextBlock Text="标注统计" FontWeight="Bold" FontSize="14" Margin="0,16,0,8"/>
                <TextBlock Text="{Binding TotalAnnotationCount, StringFormat='总计: {0}'}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding TotalBoxCount, StringFormat='边界框: {0}'}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding TotalPolygonCount, StringFormat='多边形: {0}'}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding TotalObbCount, StringFormat='OBB: {0}'}" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding ClassDistributionText}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- 质量审查 -->
                <TextBlock Text="质量审查" FontWeight="Bold" Margin="0,16,0,8"/>
                <TextBlock Text="{Binding ReviewSummaryText}" TextWrapping="Wrap" FontSize="12"/>
                <Button Content="跳转到未标注图像" Command="{Binding GotoNextUnannotatedCommand}"
                        Margin="0,8,0,0" Style="{StaticResource MaterialDesignFlatButton}"
                        IsEnabled="{Binding HasUnannotatedImages}"/>

                <!-- 使用说明 -->
                <TextBlock Text="使用说明" FontWeight="Bold" FontSize="14" Margin="0,8,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#757575" FontSize="12">
                    1. 在左侧面板创建或打开项目
                    2. 添加图像文件到项目
                    3. 在中间面板拖拽绘制边界框
                    4. 选择类别后绘制新边界框
                    5. 导出为 YOLO 格式数据集
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
