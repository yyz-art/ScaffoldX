<UserControl x:Class="ScaffoldX.App.Views.Step2BasicInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48,36">

            <!-- 步骤标题 -->
            <TextBlock Text="填写基础信息" Style="{StaticResource StepTitleStyle}"/>
            <TextBlock Text="配置项目的基本属性，这些信息将用于生成解决方案文件、命名空间和程序集信息。"
                       Style="{StaticResource StepSubtitleStyle}"/>

            <materialDesign:Card UniformCornerRadius="4"
                                  materialDesign:ElevationAssist.Elevation="Dp2"
                                  Padding="28,24"
                                  Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 项目名称 -->
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBox materialDesign:HintAssist.Hint="项目名称 *"
                                 materialDesign:HintAssist.IsFloating="True"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding ProjectNameError}"
                                   Style="{StaticResource ErrorTextStyle}"
                                   Visibility="{Binding ProjectNameError, Converter={StaticResource StringToVisibilityConverter}}"/>
                        <TextBlock Text="须以字母开头，仅含字母、数字、下划线，最长50字符"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding ProjectNameError, Converter={StaticResource InverseStringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- 命名空间前缀 -->
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBox materialDesign:HintAssist.Hint="命名空间前缀"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding NamespacePrefix, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="自动由项目名称生成，可手动修改"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- 存储路径 -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="存储路径 *"
                                     materialDesign:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding BrowseOutputPathCommand}"
                                    Width="80"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="16" Height="16"/>
                                    <TextBlock Text="浏览" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding OutputPathError}"
                                   Style="{StaticResource ErrorTextStyle}"
                                   Visibility="{Binding OutputPathError, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- 目标 UI 框架 -->
                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <ComboBox materialDesign:HintAssist.Hint="目标 UI 框架"
                                  materialDesign:HintAssist.IsFloating="True"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  SelectedValue="{Binding UIFramework}">
                            <ComboBoxItem Content="WPF"/>
                            <ComboBoxItem Content="Avalonia"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- .NET 版本 -->
                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <ComboBox materialDesign:HintAssist.Hint=".NET 版本"
                                  materialDesign:HintAssist.IsFloating="True"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  SelectedValue="{Binding DotNetVersion}">
                            <ComboBoxItem Content=".NET 10"/>
                            <ComboBoxItem Content=".NET 8"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 项目描述 -->
                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBox materialDesign:HintAssist.Hint="项目描述（可选）"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding ProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="72"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="将写入生成的 README.md 和程序集信息"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- 底部预览文字 -->
            <materialDesign:Card Margin="0,16,0,0"
                                  UniformCornerRadius="4"
                                  materialDesign:ElevationAssist.Elevation="Dp1"
                                  Padding="20,12"
                                  Background="#F3F8FF">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="EyeOutline"
                                              Width="16" Height="16"
                                              Foreground="{StaticResource PrimaryBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PreviewText}"
                               Style="{StaticResource PreviewTextStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
