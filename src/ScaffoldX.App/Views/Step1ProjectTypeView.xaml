<UserControl x:Class="ScaffoldX.App.Views.Step1ProjectTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48,36">

            <!-- 步骤标题 -->
            <TextBlock Text="选择项目类型" Style="{StaticResource StepTitleStyle}"/>
            <TextBlock Text="请选择您要生成的工业上位机项目类型，不同类型将生成不同的项目骨架和依赖。"
                       Style="{StaticResource StepSubtitleStyle}"/>

            <!-- 三个类型卡片横排 -->
            <UniformGrid Columns="3" Rows="1" Margin="0,8,0,0">

                <!-- 工业采集卡片 -->
                <Border Margin="0,0,12,0"
                        Width="280" Height="200"
                        Style="{StaticResource TypeCardBorderStyle}"
                        BorderBrush="{Binding CollectionBorderBrush}">
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SelectTypeCommand}"
                                      CommandParameter="Collection"/>
                    </Border.InputBindings>
                    <Grid>
                        <!-- 选中指示条 -->
                        <Border VerticalAlignment="Top"
                                Height="4"
                                CornerRadius="4,4,0,0"
                                Background="{StaticResource PrimaryBrush}"
                                Visibility="{Binding IsCollectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="16">
                            <materialDesign:PackIcon Kind="Factory"
                                                      Width="48" Height="48"
                                                      HorizontalAlignment="Center"
                                                      Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="工业采集"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,6"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="S7Net / Modbus / OPC UA"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 视觉检测卡片 -->
                <Border Margin="6,0"
                        Width="280" Height="200"
                        Style="{StaticResource TypeCardBorderStyle}"
                        BorderBrush="{Binding VisionBorderBrush}">
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SelectTypeCommand}"
                                      CommandParameter="Vision"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border VerticalAlignment="Top"
                                Height="4"
                                CornerRadius="4,4,0,0"
                                Background="{StaticResource PrimaryBrush}"
                                Visibility="{Binding IsVisionSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="16">
                            <materialDesign:PackIcon Kind="Camera"
                                                      Width="48" Height="48"
                                                      HorizontalAlignment="Center"
                                                      Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="视觉检测"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,6"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="海康 / 大华 / Basler + AI 推理"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 系统定制卡片 -->
                <Border Margin="12,0,0,0"
                        Width="280" Height="200"
                        Style="{StaticResource TypeCardBorderStyle}"
                        BorderBrush="{Binding SystemBorderBrush}">
                    <Border.Effect>
                        <DropShadowEffect Color="#20000000" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding SelectTypeCommand}"
                                      CommandParameter="System"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border VerticalAlignment="Top"
                                Height="4"
                                CornerRadius="4,4,0,0"
                                Background="{StaticResource PrimaryBrush}"
                                Visibility="{Binding IsSystemSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="16">
                            <materialDesign:PackIcon Kind="Cog"
                                                      Width="48" Height="48"
                                                      HorizontalAlignment="Center"
                                                      Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="系统定制"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,6"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="用户管理 / 角色权限 / 审计日志"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- 选中类型描述面板 -->
            <materialDesign:Card Margin="0,24,0,0"
                                  UniformCornerRadius="4"
                                  materialDesign:ElevationAssist.Elevation="Dp1"
                                  Padding="20,16"
                                  Background="White">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                              Width="18" Height="18"
                                              Foreground="{StaticResource PrimaryBrush}"
                                              VerticalAlignment="Top"
                                              Margin="0,1,10,0"/>
                    <TextBlock Text="{Binding TypeDescription}"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
