<UserControl x:Class="ScaffoldX.App.Views.Step4ConfirmGenerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:ScaffoldX.App.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceBrush}">

    <Grid Margin="24,24,24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 步骤标题 -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
            <TextBlock Text="确认并生成" Style="{StaticResource StepTitleStyle}"/>
            <TextBlock Text="请确认以下将生成的文件结构和项目信息，确认无误后点击&quot;开始生成&quot;。"
                       Style="{StaticResource StepSubtitleStyle}"
                       Margin="0"/>
        </StackPanel>

        <!-- 左侧：文件树预览 -->
        <materialDesign:Card Grid.Row="1" Grid.Column="0"
                              UniformCornerRadius="4"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,12"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderTree"
                                                  Width="18" Height="18"
                                                  Foreground="{StaticResource PrimaryBrush}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"/>
                        <TextBlock Text="将生成的文件结构"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TreeView Grid.Row="1"
                           ItemsSource="{Binding FileTreeRoot}"
                           Padding="8"
                           BorderThickness="0">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeNode}"
                                                   ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <materialDesign:PackIcon Width="14" Height="14"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,5,0">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="FileOutline"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                    <Setter Property="Kind" Value="Folder"/>
                                                    <Setter Property="Foreground" Value="#F9A825"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="12"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </materialDesign:Card>

        <!-- 右侧：统计面板 + 生成控制 -->
        <StackPanel Grid.Row="1" Grid.Column="2">

            <!-- 统计信息卡片 -->
            <materialDesign:Card UniformCornerRadius="4"
                                  materialDesign:ElevationAssist.Elevation="Dp2"
                                  Padding="20,16"
                                  Background="White">
                <StackPanel>
                    <TextBlock Text="项目信息"
                               FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <!-- 项目名称 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="项目名称"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0" Width="80"/>
                        <TextBlock Grid.Column="1" Text="{Binding ProjectName}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <!-- 项目类型 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="项目类型" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="{Binding ProjectTypeDisplay}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <!-- 目标框架 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="目标框架" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="{Binding TargetFrameworkDisplay}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <!-- 预估文件数 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="预估文件" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="{Binding EstimatedFileCount, StringFormat={}{0} 个}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>

                    <!-- 输出路径 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="输出路径" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="{Binding OutputPath}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- 生成按钮 -->
            <Button Margin="0,12,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding GenerateCommand}"
                    HorizontalAlignment="Stretch"
                    Height="44">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="RocketLaunch"
                                              Width="18" Height="18"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding GenerateButtonText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 进度条（生成中显示） -->
            <StackPanel Margin="0,12,0,0"
                        Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Value="{Binding Progress}"
                             Maximum="100"
                             Height="6"
                             materialDesign:TransitionAssist.DisableTransitions="False"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 完成后操作按钮 -->
            <StackPanel Margin="0,12,0,0"
                        Visibility="{Binding IsCompleted, Converter={StaticResource BooleanToVisibilityConverter}}">

                <!-- 成功状态 -->
                <StackPanel Visibility="{Binding IsError, Converter={StaticResource InverseBoolToVisConverter}}">
                    <Border Background="#E8F5E9" CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CheckCircle"
                                                      Width="18" Height="18"
                                                      Foreground="{StaticResource SuccessBrush}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource SuccessBrush}"/>
                                <TextBlock Text="{Binding ElapsedText}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenFolderCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="打开文件夹" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenInVsCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="MicrosoftVisualStudio" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="用 Visual Studio 打开" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 错误状态 -->
                <Border Background="#FFEBEE" CornerRadius="4" Padding="12,10"
                        Visibility="{Binding IsError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle"
                                                  Width="18" Height="18"
                                                  Foreground="{StaticResource ErrorBrush}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,1,8,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>

        <!-- 底部状态栏（生成中时跨全宽显示） -->
        <materialDesign:Card Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                              Margin="0,12,0,0"
                              UniformCornerRadius="4"
                              materialDesign:ElevationAssist.Elevation="Dp1"
                              Padding="16,10"
                              Background="White"
                              Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Progress, StringFormat={}{0}%}"
                           FontSize="12" FontWeight="Medium"
                           Foreground="{StaticResource PrimaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </materialDesign:Card>

    </Grid>
</UserControl>
