<UserControl x:Class="ScaffoldX.Plugin.Scaffold.Views.Step4SystemConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="系统配置"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                       Margin="0,0,0,24"/>

            <!-- 用户管理配置 -->
            <md:Card Grid.Row="1" Margin="0,0,0,24">
                <StackPanel Margin="24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <md:PackIcon Kind="AccountMultiple" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="用户管理"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,16"/>

                    <CheckBox IsChecked="{Binding EnableUserManagement}"
                              Content="启用用户管理系统"
                              Margin="0,0,0,16"/>

                    <StackPanel IsEnabled="{Binding EnableUserManagement}" Margin="24,0,0,0">
                        <CheckBox IsChecked="{Binding EnableRoleBasedAccess}"
                                  Content="启用基于角色的访问控制 (RBAC)"
                                  Margin="0,0,0,12"/>

                        <CheckBox IsChecked="{Binding EnableUserRegistration}"
                                  Content="允许用户自助注册"
                                  Margin="0,0,0,12"/>

                        <CheckBox IsChecked="{Binding EnablePasswordPolicy}"
                                  Content="启用密码策略"
                                  Margin="0,0,0,12"/>

                        <StackPanel IsEnabled="{Binding EnablePasswordPolicy}" Margin="24,0,0,16">
                            <TextBlock Text="密码最小长度"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Margin="0,0,0,4"/>
                            <Slider Minimum="6"
                                    Maximum="32"
                                    Value="{Binding PasswordMinLength}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding PasswordMinLength, StringFormat={}{0} 位}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.6"/>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding EnableSessionTimeout}"
                                  Content="启用会话超时"
                                  Margin="0,0,0,12"/>

                        <StackPanel IsEnabled="{Binding EnableSessionTimeout}" Margin="24,0,0,0">
                            <TextBlock Text="超时时间 (分钟)"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Margin="0,0,0,4"/>
                            <ComboBox SelectedItem="{Binding SessionTimeoutMinutes}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Padding="12,8">
                                <ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="60"/>
                                <ComboBoxItem Content="120"/>
                                <ComboBoxItem Content="240"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </md:Card>

            <!-- 主题配置 -->
            <md:Card Grid.Row="2" Margin="0,0,0,24">
                <StackPanel Margin="24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <md:PackIcon Kind="Palette" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="主题设置"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,16"/>

                    <TextBlock Text="选择主题"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <!-- 浅色主题 -->
                        <md:Card Width="150"
                                 Margin="0,0,16,0"
                                 Padding="16"
                                 Background="{Binding LightThemeCardBrush}"
                                 Cursor="Hand">
                            <md:Card.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectLightThemeCommand}"/>
                            </md:Card.InputBindings>
                            <StackPanel HorizontalAlignment="Center">
                                <md:PackIcon Kind="WeatherSunny" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="浅色"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </md:Card>

                        <!-- 深色主题 -->
                        <md:Card Width="150"
                                 Margin="0,0,16,0"
                                 Padding="16"
                                 Background="{Binding DarkThemeCardBrush}"
                                 Cursor="Hand">
                            <md:Card.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectDarkThemeCommand}"/>
                            </md:Card.InputBindings>
                            <StackPanel HorizontalAlignment="Center">
                                <md:PackIcon Kind="WeatherNight" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="深色"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </md:Card>

                        <!-- 跟随系统 -->
                        <md:Card Width="150"
                                 Padding="16"
                                 Background="{Binding SystemThemeCardBrush}"
                                 Cursor="Hand">
                            <md:Card.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectSystemThemeCommand}"/>
                            </md:Card.InputBindings>
                            <StackPanel HorizontalAlignment="Center">
                                <md:PackIcon Kind="DesktopClassic" Width="40" Height="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="跟随系统"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </md:Card>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding EnableAutoThemeSwitch}"
                              Content="根据时间自动切换主题 (6:00-18:00 浅色, 其他时间深色)"
                              Visibility="{Binding IsSystemThemeSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="强调色"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               Margin="0,16,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton IsChecked="{Binding IsAccentBlue, Mode=TwoWay}"
                                     GroupName="AccentColor"
                                     Margin="0,0,12,0">
                            <Ellipse Width="24" Height="24" Fill="#2196F3"/>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsAccentRed, Mode=TwoWay}"
                                     GroupName="AccentColor"
                                     Margin="0,0,12,0">
                            <Ellipse Width="24" Height="24" Fill="#F44336"/>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsAccentGreen, Mode=TwoWay}"
                                     GroupName="AccentColor"
                                     Margin="0,0,12,0">
                            <Ellipse Width="24" Height="24" Fill="#4CAF50"/>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsAccentPurple, Mode=TwoWay}"
                                     GroupName="AccentColor"
                                     Margin="0,0,12,0">
                            <Ellipse Width="24" Height="24" Fill="#9C27B0"/>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsAccentOrange, Mode=TwoWay}"
                                     GroupName="AccentColor"
                                     Margin="0,0,12,0">
                            <Ellipse Width="24" Height="24" Fill="#FF9800"/>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsAccentTeal, Mode=TwoWay}"
                                     GroupName="AccentColor">
                            <Ellipse Width="24" Height="24" Fill="#009688"/>
                        </RadioButton>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding EnableAnimations}"
                              Content="启用界面动画效果"
                              Margin="0,0,0,8"/>
                </StackPanel>
            </md:Card>

            <!-- 高级设置 -->
            <md:Card Grid.Row="3">
                <StackPanel Margin="24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <md:PackIcon Kind="Settings" Width="28" Height="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Text="高级设置"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Separator Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox Grid.Column="0" Grid.Row="0"
                                  IsChecked="{Binding EnableLogging}"
                                  Content="启用日志记录"
                                  Margin="0,0,0,12"/>

                        <CheckBox Grid.Column="1" Grid.Row="0"
                                  IsChecked="{Binding EnableAutoUpdate}"
                                  Content="启用自动更新检查"
                                  Margin="0,0,0,12"/>

                        <CheckBox Grid.Column="0" Grid.Row="1"
                                  IsChecked="{Binding EnableTelemetry}"
                                  Content="启用匿名使用统计"
                                  Margin="0,0,0,12"/>

                        <CheckBox Grid.Column="1" Grid.Row="1"
                                  IsChecked="{Binding EnableCrashReporting}"
                                  Content="启用崩溃报告"
                                  Margin="0,0,0,12"/>
                    </Grid>

                    <StackPanel IsEnabled="{Binding EnableLogging}" Margin="0,8,0,0">
                        <TextBlock Text="日志级别"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Margin="0,0,0,4"/>
                        <ComboBox SelectedItem="{Binding LogLevel}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Padding="12,8"
                                  Width="200"
                                  HorizontalAlignment="Left">
                            <ComboBoxItem Content="Verbose"/>
                            <ComboBoxItem Content="Debug"/>
                            <ComboBoxItem Content="Information"/>
                            <ComboBoxItem Content="Warning"/>
                            <ComboBoxItem Content="Error"/>
                            <ComboBoxItem Content="Fatal"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </md:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
