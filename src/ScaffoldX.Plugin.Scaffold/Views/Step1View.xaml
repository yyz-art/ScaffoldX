<UserControl x:Class="ScaffoldX.Plugin.Scaffold.Views.Step1View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:ScaffoldX.Plugin.Scaffold.Views"
             xmlns:converters="clr-namespace:ScaffoldX.Plugin.Scaffold.Converters">
    <UserControl.Resources>
        <converters:StringIsNotEmptyToVisibilityConverter x:Key="StringIsNotEmptyToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="基础信息"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,24"/>

        <!-- 项目名称 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBox md:HintAssist.Hint="项目名称"
                     Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Padding="12,8"
                     Margin="0,0,0,8"/>
            <TextBlock Text="{Binding ProjectNameError}"
                       Foreground="{StaticResource MaterialDesignValidationErrorBrush}"
                       FontSize="12"
                       Visibility="{Binding ProjectNameError, Converter={StaticResource StringIsNotEmptyToVisibilityConverter}}"/>
        </StackPanel>

        <!-- 输出目录 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         md:HintAssist.Hint="输出目录"
                         Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Padding="12,8"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Content="浏览..."
                        Command="{Binding BrowseCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
            </Grid>
            <TextBlock Text="{Binding OutputDirectoryError}"
                       Foreground="{StaticResource MaterialDesignValidationErrorBrush}"
                       FontSize="12"
                       Margin="0,4,0,0"
                       Visibility="{Binding OutputDirectoryError, Converter={StaticResource StringIsNotEmptyToVisibilityConverter}}"/>
        </StackPanel>

        <!-- 项目类型选择 -->
        <StackPanel Grid.Row="3">
            <TextBlock Text="项目类型"
                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                       Margin="0,0,0,12"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 数据采集 -->
                <md:Card Grid.Column="0" 
                         Margin="0,0,8,0" 
                         Padding="16"
                         Background="{Binding CollectionCardBrush}"
                         MouseLeftButtonDown="OnCollectionCardClick">
                    <StackPanel HorizontalAlignment="Center">
                        <md:PackIcon Kind="Database" 
                                     Width="48" 
                                     Height="48"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,8"/>
                        <TextBlock Text="数据采集"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="PLC、Modbus、OPC UA"
                                   FontSize="12"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </md:Card>

                <!-- 视觉 -->
                <md:Card Grid.Column="1" 
                         Margin="4,0,4,0" 
                         Padding="16"
                         Background="{Binding VisionCardBrush}"
                         MouseLeftButtonDown="OnVisionCardClick">
                    <StackPanel HorizontalAlignment="Center">
                        <md:PackIcon Kind="Eye" 
                                     Width="48" 
                                     Height="48"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,8"/>
                        <TextBlock Text="视觉"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="相机、YOLO、SAM3"
                                   FontSize="12"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </md:Card>

                <!-- 系统 -->
                <md:Card Grid.Column="2" 
                         Margin="8,0,0,0" 
                         Padding="16"
                         Background="{Binding SystemCardBrush}"
                         MouseLeftButtonDown="OnSystemCardClick">
                    <StackPanel HorizontalAlignment="Center">
                        <md:PackIcon Kind="Cog" 
                                     Width="48" 
                                     Height="48"
                                     HorizontalAlignment="Center"
                                     Margin="0,0,0,8"/>
                        <TextBlock Text="系统"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="用户管理、主题切换"
                                   FontSize="12"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </md:Card>
            </Grid>
            
            <TextBlock Text="{Binding ProjectTypeError}"
                       Foreground="{StaticResource MaterialDesignValidationErrorBrush}"
                       FontSize="12"
                       Margin="0,8,0,0"
                       Visibility="{Binding ProjectTypeError, Converter={StaticResource StringIsNotEmptyToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
